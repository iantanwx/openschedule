{
  "name": "openschedule",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:convex": "pnpm --filter @openschedule/convex dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:web": "pnpm --filter web dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@openschedule/typescript-config": "workspace:*",
    "oxlint": "^1",
    "turbo": "^2.9.15",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4"
}
